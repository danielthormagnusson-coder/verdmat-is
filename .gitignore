# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
__pycache__/

# audit staging databases (large; rebuildable from scrapers)
audit/*.db
audit/*.db-shm
audit/*.db-wal

# scraper raw-layer SQLite DBs (SCRAPER_SPEC_v2 §2.1) — live OUTSIDE the repo on
# D:\ by convention (scraper_data/); these globs are belt-and-suspenders against
# a mis-set cwd so multi-GB blob DBs never land in a commit.
scraper_data/
*.db
*.db-shm
*.db-wal

# audit routine runtime logs (regenerable). Incident/recovery-evidence logs
# bypass this via `git add -f` (e.g., hms_full_scrape*.log captures the
# 58h buggy-run that motivated the recovery — non-regenerable evidence).
audit/*.log
audit/*.flag

# Group C run_monthly local JSON run-logs (regenerable; pipeline_runs +
# pipeline_steps in Supabase are the canonical record).
audit/monthly_runs/

# Orchestrator step-script logs (<script>_log_<date>.txt). The 5 D:\ monthly
# scripts write these to their resolved LOG_PATH/D_DRIVE; if CWD is mis-set
# they leak into the repo working dir (as run id=2's pre-fix CWD bug showed).
# Listing the 5 known patterns prevents accidental commits, intentionally
# (not a wildcard).
refresh_cpi_log_*.txt
refresh_kaupskra_log_*.txt
rebuild_training_data_log_*.txt
monthly_recalibration_log_*.txt
validate_metrics_log_*.txt

# large regenerable fastnum manifests (rebuilt from Supabase / kaupskra.csv;
# 3 scripts reference them by name — files stay on disk, just not tracked).
audit/stage_a_fastnum_manifest.txt
audit/supabase_fastnums.txt
audit/known_real_fastnums.txt

# opin_gogn harvest: downloaded public datasets live at ../data/raw/opin_gogn
# (sibling of repo root, already outside git). This guard covers app/data too.
# Never git add the harvested data — only pipelines/opin_gogn/harvest.py is tracked.
data/raw/opin_gogn/

# heimildasafn: raw source archive for the monthly Fable market reports
# (PDFs/HTML/CSV stay on disk + nightly backup; only the manifest and the
# frettir metadata JSONs — headline/date/link, no article content — are tracked).
heimildasafn/**
!heimildasafn/MANIFEST.json
!heimildasafn/frettir/
!heimildasafn/frettir/**

# cc4: radgogn ur prod-DB - aldrei i git (public repo)
docs/fable_prep/prototypes/holdout_rows.csv

# cc21: env.local UTAN punkts er EKKI gripid af `.env*` hér að ofan. Skrain a
# D:\ rot ber lifandi SUPABASE_SERVICE_ROLE_KEY / ANTHROPIC_API_KEY /
# OPS_PASSWORD / R2-lykla. Verjum bad afbrigdi beinlinis (audit D_UTTEKT §5.4).
env.local
env.*.local
*.env.local

# cc21: fable_prep uttektarsafnid - GOGN hunsud, SKJOL trackanleg.
# ~90 CSV + 1 parquet satu otrackud EN EKKI hunsud; eitt `git add .` hefdi
# committad thau i opinbert repo. Reglan heldur *.md (uttektunum sjalfum)
# trackanlegum. Heimild: D_UTTEKT_20260718T095336Z §5.3.
docs/fable_prep/**/*.csv
docs/fable_prep/**/*.parquet
docs/fable_prep/**/*.pkl

# Radalaga JSON undir fable_prep - EKKI gripid af reglunum ad ofan. Tvaer af
# radalaga skronum fjorum sem uttektin nafngreindi eru .json, ekki .csv.
docs/fable_prep/audit/comp_e2e_sample_comps.json
docs/fable_prep/audit/comps_v2_sample_audit.json

# audit.zip ber 56 CSV innani (thar a medal comp_e2e_groundtruth.csv) og fer
# thvi FRAMHJA *.csv-reglunni. Safn, ekki skjal.
docs/fable_prep/audit.zip
