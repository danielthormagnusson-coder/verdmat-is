# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
__pycache__/

# audit staging databases (large; rebuildable from scrapers)
audit/*.db
audit/*.db-shm
audit/*.db-wal

# audit routine runtime logs (regenerable). Incident/recovery-evidence logs
# bypass this via `git add -f` (e.g., hms_full_scrape*.log captures the
# 58h buggy-run that motivated the recovery — non-regenerable evidence).
audit/*.log
audit/*.flag

# Group C run_monthly local JSON run-logs (regenerable; pipeline_runs +
# pipeline_steps in Supabase are the canonical record).
audit/monthly_runs/

# large regenerable fastnum manifests (rebuilt from Supabase / kaupskra.csv;
# 3 scripts reference them by name — files stay on disk, just not tracked).
audit/stage_a_fastnum_manifest.txt
audit/supabase_fastnums.txt
audit/known_real_fastnums.txt
